# Copy this to .env and fill in the values

# Mailgun — for OTP login emails
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.escapecollective.com
MAILGUN_FROM=EC Social Tool <noreply@mg.escapecollective.com>
# EU accounts only — remove this line if using US Mailgun:
# MAILGUN_API_URL=https://api.eu.mailgun.net

# Session — generate a long random string, e.g: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Admins — comma-separated, can manage the user list
ADMIN_EMAILS=wade@escapecollective.com

# Server port (Railway sets this automatically)
PORT=3000
